{
  "name": "operation-planner-ufe",
  "version": "0.0.1",
  "description": "Operating Room Planner micro front-end",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2017": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/operation-planner-ufe/operation-planner-ufe.esm.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build --docs",
    "start:app": "stencil build --dev --watch --serve",
    "start:mock": "run-s convert-openapi mock-api",
    "start": "run-p -r start:mock start:app",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate",
    "convert-openapi": "js-yaml ./api/or-planner.openapi.yaml > .openapi.json",
    "mock-api": "open-api-mocker --schema .openapi.json --port 5000",
    "openapi": "openapi-generator-cli generate"
  },
  "dependencies": {
    "@material/web": "^1.5.1",
    "@stencil/core": "^4.20.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.13.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "js-yaml": "^4.1.0",
    "npm-run-all": "^4.1.5",
    "open-api-mocker": "^2.0.0",
    "puppeteer": "^22.13.0"
  },
  "license": "MIT"
}
